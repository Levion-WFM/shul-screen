{
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/weekly-schedule/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://beismedrashdjackson21.com https://www.beismedrashdjackson21.com https://shul-website.vercel.app https://*.vercel.app"
        }
      ]
    },
    {
      "source": "/api/weekly-schedule",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
